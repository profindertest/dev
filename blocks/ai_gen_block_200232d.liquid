{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
    z-index: 1;
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ block.settings.active_line_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 80px;
    opacity: 0.4;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    position: relative;
    width: calc(50% - 40px);
    padding: 24px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: 0;
    margin-right: auto;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: 0;
  }

  .ai-timeline-marker-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 30px;
    width: {{ block.settings.marker_size }}px;
    height: {{ block.settings.marker_size }}px;
    background-color: {{ block.settings.marker_color }};
    border: {{ block.settings.marker_border_width }}px solid {{ block.settings.background_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-marker-{{ ai_gen_id }} {
    background-color: {{ block.settings.active_marker_color }};
    transform: translate(-50%, -50%) scale(1.2);
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      width: calc(100% - 60px);
      margin-left: 60px !important;
      margin-right: 0 !important;
    }

    .ai-timeline-marker-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      margin-bottom: 60px;
    }
  }
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    {% for i in (1..5) %}
      {% liquid
        assign date_key = 'item_' | append: i | append: '_date'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        assign enabled_key = 'item_' | append: i | append: '_enabled'

        assign item_date = block.settings[date_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
        assign item_enabled = block.settings[enabled_key]
      %}

      {% if item_enabled %}
        <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
          <div class="ai-timeline-marker-{{ ai_gen_id }}"></div>
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if item_date != blank %}
              <div class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</div>
            {% endif %}
            {% if item_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}
            {% if item_description != blank %}
              <div class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</scroll-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.timelineContainer = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.progressBar = this.querySelector('.ai-timeline-progress-{{ ai_gen_id }}');
        this.timelineContainer = this.querySelector('.ai-timeline-container-{{ ai_gen_id }}');
        
        if (this.items.length > 0) {
          this.setupScrollListener();
          this.updateTimeline();
        }
      }

      setupScrollListener() {
        let ticking = false;
        
        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              this.updateTimeline();
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      updateTimeline() {
        const windowHeight = window.innerHeight;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        let activeIndex = -1;
        let maxProgress = 0;

        this.items.forEach((item, index) => {
          const rect = item.getBoundingClientRect();
          const itemTop = rect.top + scrollTop;
          const itemMiddle = itemTop + (rect.height / 2);
          const viewportMiddle = scrollTop + (windowHeight / 2);

          if (viewportMiddle >= itemMiddle) {
            activeIndex = index;
            item.classList.add('active');
          } else {
            item.classList.remove('active');
          }
        });

        if (activeIndex >= 0 && this.items.length > 0) {
          const lastActiveItem = this.items[activeIndex];
          const containerRect = this.timelineContainer.getBoundingClientRect();
          const containerTop = containerRect.top + scrollTop;
          const itemRect = lastActiveItem.getBoundingClientRect();
          const itemTop = itemRect.top + scrollTop;
          
          const relativePosition = itemTop - containerTop;
          const containerHeight = this.timelineContainer.offsetHeight;
          
          maxProgress = Math.min((relativePosition / containerHeight) * 100, 100);
        }

        if (this.progressBar) {
          this.progressBar.style.height = maxProgress + '%';
        }
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.updateTimeline);
      }
    }

    customElements.define('scroll-timeline-{{ ai_gen_id }}', ScrollTimeline{{ ai_gen_id }});
  })();
</script>

