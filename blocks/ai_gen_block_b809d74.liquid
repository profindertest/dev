{% doc %}
  @prompt
    need a section to upload image gallery in a collage style with the option to change collage layout., great, its fine but I don't want only max 6 images to upload, I need more, so you can add "Add More" and the collage layout dropdown will be set accordingly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collage-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 2 / 4;
    grid-row: 1 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 1 / 2;
    grid-row: 2 / 4;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2 / 3;
    grid-row: 3 / 4;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(5) {
    grid-column: 3 / 4;
    grid-row: 3 / 4;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 3 / 5;
    grid-row: 1 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 1 / 3;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 3 / 4;
    grid-row: 1 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 {
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3) {
    grid-column: 5 / 7;
    grid-row: 1 / 2;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4) {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(5) {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(6) {
    grid-column: 5 / 7;
    grid-row: 2 / 3;
  }

  .ai-collage-gallery__container-{{ ai_gen_id }}--layout-grid {
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    grid-auto-rows: 250px;
  }

  .ai-collage-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-collage-gallery__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 200px;
  }

  .ai-collage-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collage-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collage-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collage-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collage-gallery__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-1 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-2 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(5),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-3 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-4 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(1),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(2),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(3),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(4),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(5),
    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-5 .ai-collage-gallery__item-{{ ai_gen_id }}:nth-child(6) {
      grid-column: auto;
      grid-row: auto;
    }

    .ai-collage-gallery__container-{{ ai_gen_id }}--layout-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
  }
{% endstyle %}

<collage-gallery-{{ ai_gen_id }} class="ai-collage-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collage-gallery__container-{{ ai_gen_id }} ai-collage-gallery__container-{{ ai_gen_id }}--layout-{{ block.settings.layout }}">
    {% liquid
      assign max_images = 20
      if block.settings.layout == '1' or block.settings.layout == '3' or block.settings.layout == '4'
        assign max_images = 4
      elsif block.settings.layout == '2'
        assign max_images = 5
      elsif block.settings.layout == '5'
        assign max_images = 6
      endif

      assign has_any_image = false
      for i in (1..max_images)
        assign image_key = 'image_' | append: i
        assign image = block.settings[image_key]
        if image
          assign has_any_image = true
          break
        endif
      endfor
    %}

    {% for i in (1..max_images) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign image = block.settings[image_key]
      %}

      {% if image %}
        <div class="ai-collage-gallery__item-{{ ai_gen_id }}">
          <div class="ai-collage-gallery__image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ image | image_url: width: 1000 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-collage-gallery__image-{{ ai_gen_id }}"
            >
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% unless has_any_image %}
      <div class="ai-collage-gallery__item-{{ ai_gen_id }}">
        <div class="ai-collage-gallery__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-collage-gallery__empty-state-{{ ai_gen_id }}">
            Next, add images to your gallery
          </div>
        </div>
      </div>
    {% endunless %}
  </div>
</collage-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class CollageGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('collage-gallery-{{ ai_gen_id }}', CollageGallery{{ ai_gen_id }});
  })();
</script>

